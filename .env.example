# 今天吃什么 - 统一环境配置
# 复制为 .env 后按环境修改；.env 已被 Git 忽略，禁止提交真实密钥。

# Runtime
APP_ENV=development
DEMO_MODE=false
JWT_SECRET=replace-with-a-random-string-at-least-32-characters
JWT_EXPIRE_HOURS=72
LOG_LEVEL=INFO

# Local addresses
ADMIN_HOST=127.0.0.1
ADMIN_PORT=5175
VITE_API_BASE_URL=http://127.0.0.1:8002/api
CORS_ORIGINS=http://localhost:5175,http://127.0.0.1:5175

# Database (empty uses backend/whattocook.db in local development)
DATABASE_URL=
POSTGRES_PASSWORD=change-me-in-production

# WeChat
WX_APPID=
WX_SECRET=

# AI: ollama | openai_compatible | rules
AI_PROVIDER=ollama
AI_API_BASE=
AI_API_KEY=
AI_MODEL=qwen3.5:0.8b
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=qwen3.5:0.8b

# Object storage: local | s3
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# Rate limits
AUTH_RATE_LIMIT=10
CHAT_RATE_LIMIT=30

# Optional one-time administrator bootstrap (minimum password length: 10)
# Existing administrator passwords are changed in the management console.
ADMIN_USERNAME=
ADMIN_PASSWORD=
