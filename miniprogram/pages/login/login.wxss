.page-login {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  padding: 0 38rpx calc(env(safe-area-inset-bottom) + 28rpx);
  box-sizing: border-box;
  background:
    radial-gradient(circle at 50% 25%, rgba(255, 219, 137, 0.52), transparent 260rpx),
    radial-gradient(circle at 16% 10%, rgba(255, 107, 26, 0.14), transparent 190rpx),
    radial-gradient(circle at 88% 30%, rgba(255, 91, 130, 0.12), transparent 210rpx),
    linear-gradient(180deg, #fff8ef 0%, #fff5ec 46%, #fffaf5 100%);
  color: #2a1735;
}

.login-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.float-food {
  position: absolute;
  z-index: 0;
  opacity: 0.68;
  filter: drop-shadow(0 18rpx 28rpx rgba(255, 122, 26, 0.16));
}

.food-tomato {
  width: 118rpx;
  height: 118rpx;
  left: 38rpx;
  top: 118rpx;
  opacity: 0.58;
}

.food-lemon {
  width: 136rpx;
  height: 136rpx;
  left: -20rpx;
  top: 430rpx;
  opacity: 0.62;
}

.food-leaf {
  width: 64rpx;
  height: 64rpx;
  right: 220rpx;
  top: 142rpx;
  opacity: 0.58;
  transform: rotate(18deg);
}

.food-garlic {
  width: 102rpx;
  height: 102rpx;
  right: 26rpx;
  top: 260rpx;
  opacity: 0.6;
}

.food-lobster {
  width: 126rpx;
  height: 126rpx;
  right: -8rpx;
  top: 460rpx;
  opacity: 0.48;
  transform: rotate(-16deg);
}

.bg-ring {
  position: absolute;
  left: 50%;
  border-radius: 50%;
  transform: translateX(-50%) rotate(-5deg);
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 0 42rpx rgba(255, 255, 255, 0.9), inset 0 0 26rpx rgba(255, 196, 101, 0.24);
}

.ring-main {
  top: 218rpx;
  width: 700rpx;
  height: 250rpx;
}

.ring-soft {
  top: 262rpx;
  width: 430rpx;
  height: 118rpx;
  border-width: 2rpx;
  opacity: 0.54;
}

.bg-plate {
  position: absolute;
  top: 294rpx;
  left: 50%;
  width: 430rpx;
  height: 94rpx;
  border-radius: 50%;
  transform: translateX(-50%);
  background: radial-gradient(ellipse at center, rgba(255, 238, 165, 0.9) 0%, rgba(255, 194, 89, 0.32) 48%, transparent 72%);
  box-shadow: 0 0 54rpx rgba(255, 212, 114, 0.72);
}

.bg-orbit,
.light-dot {
  position: absolute;
  border-radius: 999rpx;
}

.orbit-a {
  width: 18rpx;
  height: 18rpx;
  right: 260rpx;
  top: 268rpx;
  background: #f7bd5e;
}

.orbit-b {
  width: 14rpx;
  height: 14rpx;
  left: 184rpx;
  top: 290rpx;
  background: #ff9e74;
}

.light-dot {
  width: 12rpx;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 0 22rpx rgba(255, 255, 255, 0.9);
}

.dot-one {
  left: 60rpx;
  top: 356rpx;
}

.dot-two {
  right: 72rpx;
  top: 384rpx;
}

.dot-three {
  left: 50%;
  top: 172rpx;
}

.login-hero {
  position: relative;
  z-index: 1;
  padding-top: 116rpx;
  padding-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.brand-badge {
  width: 156rpx;
  height: 156rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 28% 18%, rgba(255, 255, 255, 0.96), transparent 42%),
    linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,241,232,0.88) 100%);
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    0 24rpx 48rpx rgba(255, 122, 26, 0.18),
    0 0 0 12rpx rgba(255, 255, 255, 0.28),
    inset 0 -10rpx 0 rgba(255, 122, 26, 0.08);
}

.brand-icon {
  width: 136rpx;
  height: 136rpx;
  border-radius: 40rpx;
  box-shadow: 0 10rpx 24rpx rgba(91, 43, 111, 0.12);
}

.app-title {
  margin-top: 46rpx;
  color: #35124f;
  font-size: 86rpx;
  line-height: 1.02;
  font-weight: 950;
  text-shadow: 0 8rpx 0 rgba(255, 255, 255, 0.78), 0 16rpx 28rpx rgba(91, 43, 111, 0.14);
}

.app-subtitle {
  margin-top: 22rpx;
  max-width: 650rpx;
  color: #8b6759;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 650;
}

.benefit-row {
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin-top: 26rpx;
}

.benefit-chip {
  min-width: 184rpx;
  height: 70rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #3c1854;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(255, 217, 196, 0.94);
  box-shadow: 0 12rpx 26rpx rgba(91, 43, 111, 0.08), inset 0 -4rpx 0 rgba(255, 122, 26, 0.04);
  font-size: 26rpx;
  font-weight: 900;
}

.benefit-chip image {
  width: 34rpx;
  height: 34rpx;
}

.auth-card {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 46rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 3rpx solid rgba(255, 255, 255, 0.88);
  box-shadow:
    0 34rpx 74rpx rgba(255, 122, 26, 0.13),
    0 0 0 2rpx rgba(255, 209, 188, 0.58),
    inset 0 0 44rpx rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(18rpx);
}

.tab-bar {
  display: flex;
  min-height: 88rpx;
  background: rgba(255, 241, 232, 0.92);
  border: 2rpx solid rgba(255, 215, 194, 0.84);
  border-radius: 999rpx;
  padding: 8rpx;
  margin: 0 16rpx 24rpx;
  box-sizing: border-box;
}

.tab {
  position: relative;
  flex: 1;
  min-width: 0;
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  color: #9a776b;
  font-weight: 900;
}

.tab.active {
  color: #ff5a1f;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(91, 43, 111, 0.09), inset 0 -5rpx 0 rgba(255, 122, 26, 0.04);
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  width: 48rpx;
  height: 7rpx;
  border-radius: 999rpx;
  transform: translateX(-50%);
  background: linear-gradient(90deg, #ff3d6e 0%, #ff7a1a 100%);
}

.form-card {
  border-radius: 34rpx;
  padding: 30rpx 28rpx 34rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(91, 43, 111, 0.05);
}

.form-item {
  margin-bottom: 26rpx;
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  color: #35124f;
  font-size: 29rpx;
  font-weight: 950;
}

.input-wrap {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 22rpx;
  border-radius: 25rpx;
  border: 2rpx solid #ffcbb6;
  background: rgba(255, 255, 255, 0.84);
  box-sizing: border-box;
  box-shadow: inset 0 -6rpx 14rpx rgba(255, 122, 26, 0.03);
}

.input-icon {
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
}

.input-wrap::after {
  content: '';
  width: 2rpx;
  height: 36rpx;
  background: #ead7ce;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  color: #2a1735;
  font-size: 30rpx;
}

.input-placeholder {
  color: #a79792;
}

.eye-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.submit-btn {
  position: relative;
  width: 100%;
  min-height: 104rpx;
  line-height: 1.2;
  padding: 20rpx 34rpx;
  margin-top: 12rpx;
  border: none;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  overflow: hidden;
  background: linear-gradient(100deg, #ff5aa5 0%, #ff4f52 34%, #ff8b13 74%, #ffb13e 100%);
  box-shadow:
    0 18rpx 32rpx rgba(255, 91, 95, 0.24),
    0 8rpx 0 #e97800,
    inset 0 4rpx 9rpx rgba(255, 255, 255, 0.46);
}

.submit-btn::before {
  content: '';
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 9rpx;
  height: 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.48), transparent);
}

.submit-btn::after,
.wx-login-btn::after {
  border: none;
}

.submit-btn.is-disabled,
.wx-login-btn.is-disabled {
  opacity: 0.72;
}

.submit-btn text {
  position: relative;
  z-index: 1;
}

.submit-curl {
  font-size: 58rpx;
  line-height: 1;
  font-weight: 700;
}

.divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 38rpx 106rpx 28rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #efd8c9;
}

.divider-text {
  color: #8b766f;
  font-size: 25rpx;
  font-weight: 850;
}

.wx-login-btn {
  width: 462rpx;
  max-width: 82%;
  min-height: 94rpx;
  line-height: 1.2;
  padding: 18rpx 30rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  border: none;
  color: #ffffff;
  background: linear-gradient(180deg, #1bd773 0%, #09b95a 100%);
  box-shadow:
    0 14rpx 32rpx rgba(5, 150, 105, 0.22),
    0 7rpx 0 #07984d,
    inset 0 4rpx 9rpx rgba(255, 255, 255, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 30rpx;
  font-weight: 950;
}

.wechat-mark {
  position: relative;
  width: 62rpx;
  height: 42rpx;
  flex-shrink: 0;
}

.wechat-mark::before,
.wechat-mark::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  background: #ffffff;
}

.wechat-mark::before {
  width: 38rpx;
  height: 30rpx;
  left: 0;
  top: 4rpx;
}

.wechat-mark::after {
  width: 34rpx;
  height: 27rpx;
  right: 0;
  top: 12rpx;
}

.wechat-dot {
  position: absolute;
  z-index: 1;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: #09b95a;
}

.wechat-dot.dot-a {
  left: 13rpx;
  top: 16rpx;
}

.wechat-dot.dot-b {
  right: 13rpx;
  top: 24rpx;
}

.tip-text {
  margin-top: 22rpx;
  color: #a89288;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
}

.agreement-row {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #a89288;
  font-size: 22rpx;
  line-height: 1.35;
  text-align: center;
}

.agree-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.54;
  flex-shrink: 0;
}
