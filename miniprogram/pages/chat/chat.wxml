<view class="page-chat">
  <view class="ai-header">
    <view class="ai-profile">
      <image class="ai-avatar" src="/images/icons/ai.svg" mode="aspectFit" />
      <view class="ai-info">
        <view class="ai-name-row">
          <text class="ai-name">小厨娘</text>
          <view class="online-pill">在线</view>
        </view>
        <text class="ai-subtitle">菜单灵感、火候判断、食材替换都可以问我</text>
      </view>
    </view>
  </view>

  <scroll-view
    class="chat-messages"
    scroll-y
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
  >
    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <chat-bubble
        message="{{item.text}}"
        isUser="{{item.isUser}}"
        showAvatar="{{!item.isUser && (index === 0 || messages[index-1].isUser)}}"
      />
    </view>

    <view wx:if="{{showSuggestion}}" class="suggestion-card" bindtap="onSuggestionTap">
      <image class="suggestion-icon" src="/images/icons/dice.svg" mode="aspectFit" />
      <view>
        <text class="suggestion-title">还没决定吃什么？</text>
        <text class="suggestion-text">去摇一摇，给你组合一道今日菜单</text>
      </view>
    </view>

    <view wx:if="{{isTyping}}" class="typing-indicator" id="typing">
      <view class="typing-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
      <text class="typing-text">小厨娘正在组织做法...</text>
    </view>
  </scroll-view>

  <view wx:if="{{messages.length <= 1}}" class="quick-questions">
    <text class="quick-label">试试这样问</text>
    <view class="quick-list">
      <view
        wx:for="{{quickQuestions}}"
        wx:key="*this"
        class="quick-item"
        bindtap="onQuickQuestion"
        data-question="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view class="input-area">
    <view class="input-row">
      <input
        class="message-input"
        placeholder="输入你的烹饪问题..."
        value="{{inputText}}"
        bindinput="onInputChange"
        bindconfirm="onSend"
        confirm-type="send"
        adjust-position="{{true}}"
      />
      <view class="action-btn voice-btn" bindtap="onVoiceInput">
        <text class="voice-mark">Mic</text>
      </view>
      <view class="action-btn send-btn {{inputText ? 'active' : ''}}" bindtap="onSend">
        <text class="send-mark">➜</text>
      </view>
    </view>
  </view>
</view>
