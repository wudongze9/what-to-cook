<view class="page-chat">
  <view class="ai-header">
    <image class="ai-header-pot" src="/images/icons/pot.svg" mode="aspectFit" />
    <image class="ai-header-leaf" src="/images/icons/leaf.svg" mode="aspectFit" />
    <view class="ai-profile">
      <view class="ai-avatar-wrap {{isSpeaking ? 'speaking' : ''}} {{isTyping ? 'thinking' : ''}}">
        <image class="ai-avatar" src="/images/icons/ai.svg" mode="aspectFit" />
        <view class="avatar-pulse"></view>
      </view>
      <view class="ai-info">
        <view class="ai-name-row">
          <text class="ai-name">小厨娘</text>
          <view class="online-pill">
            <view class="online-dot"></view>
            <text>在线</text>
          </view>
        </view>
        <text class="ai-subtitle">直接问我“某道菜怎么做”，我会给你步骤、火候和替换建议。</text>
        <view class="ai-actions">
          <button class="ask-recipe-btn" bindtap="onAskRecipeGuide">
            <image class="ask-recipe-icon" src="/images/icons/chef.svg" mode="aspectFit" />
            <text>问菜怎么做</text>
          </button>
          <button class="mini-action-btn" bindtap="onSuggestionTap">
            <image class="mini-action-icon" src="/images/icons/dice.svg" mode="aspectFit" />
          </button>
        </view>
      </view>
    </view>
  </view>

  <scroll-view
    class="chat-messages"
    scroll-y
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
  >
    <view class="recipe-ask-card">
      <view class="recipe-ask-head">
        <image class="recipe-ask-icon" src="/images/icons/pot.svg" mode="aspectFit" />
        <view>
          <text class="recipe-ask-title">想学哪道菜？</text>
          <text class="recipe-ask-desc">点一下直接提问，也可以在底部自己输入菜名。</text>
        </view>
      </view>
      <view class="recipe-prompt-list">
        <view
          wx:for="{{recipePrompts}}"
          wx:key="text"
          class="recipe-prompt"
          bindtap="onRecipePrompt"
          data-question="{{item.question}}"
        >
          <image class="recipe-prompt-icon" src="{{item.icon}}" mode="aspectFit" />
          <text>{{item.text}}</text>
        </view>
      </view>
    </view>

    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="msg-row">
      <chat-bubble
        message="{{item.text}}"
        isUser="{{item.isUser}}"
        showAvatar="{{!item.isUser && (index === 0 || messages[index-1].isUser)}}"
      />
      <view
        wx:if="{{!item.isUser}}"
        class="msg-tts-row"
        catchtap="onToggleTTS"
        data-index="{{index}}"
      >
        <image
          class="tts-icon"
          src="{{item.playing ? '/images/icons/pause.svg' : '/images/icons/play.svg'}}"
          mode="aspectFit"
        />
        <text class="tts-label">{{item.playing ? '停止播报' : '语音播报'}}</text>
      </view>
    </view>

    <view wx:if="{{showSuggestion}}" class="suggestion-card" bindtap="onSuggestionTap">
      <image class="suggestion-icon" src="/images/icons/dice.svg" mode="aspectFit" />
      <view>
        <text class="suggestion-title">还没决定吃什么？</text>
        <text class="suggestion-text">去摇一摇，给你组合一道今日菜单</text>
      </view>
    </view>

    <view wx:if="{{isTyping}}" class="typing-indicator" id="typing">
      <view class="typing-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
      <text class="typing-text">小厨娘正在整理做法...</text>
    </view>

    <view id="msg-bottom" class="chat-bottom-spacer"></view>
  </scroll-view>

  <view wx:if="{{messages.length <= 1}}" class="quick-questions">
    <text class="quick-label">试试这样问</text>
    <scroll-view scroll-x class="quick-scroll" show-scrollbar="{{false}}">
      <view class="quick-list">
        <view
          wx:for="{{quickQuestions}}"
          wx:key="*this"
          class="quick-item"
          bindtap="onQuickQuestion"
          data-question="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="input-area">
    <view class="input-row">
      <input
        class="message-input"
        placeholder="例如：番茄炒蛋怎么做？"
        value="{{inputText}}"
        bindinput="onInputChange"
        bindconfirm="onSend"
        confirm-type="send"
        adjust-position="{{true}}"
      />
      <view
        class="action-btn voice-btn {{isRecording ? 'recording' : ''}}"
        bindtap="onVoiceTap"
      >
        <image class="input-icon" src="/images/icons/mic.svg" mode="aspectFit" />
      </view>
      <button class="send-text-btn {{(inputText || isTyping) ? 'active' : ''}} {{(!inputText && !isTyping) ? 'disabled' : ''}}" bindtap="onSend" disabled="{{!inputText && !isTyping}}">
        {{isTyping ? '停止' : '发送'}}
      </button>
    </view>
  </view>

  <view wx:if="{{isRecording}}" class="recording-overlay">
    <view class="recording-modal">
      <view class="recording-waves">
        <view class="wave-bar" wx:for="{{[1,2,3,4,5,6,7]}}" wx:key="*this" style="animation-delay: {{index * 0.1}}s;"></view>
      </view>
      <text class="recording-text">{{recognizeText ? '识别中...' : '正在聆听...'}}</text>
      <text wx:if="{{recognizeText}}" class="recording-result">{{recognizeText}}</text>
      <text class="recording-hint">再次点击麦克风结束并发送</text>
    </view>
  </view>
</view>
