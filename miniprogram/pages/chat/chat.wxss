.page-chat {
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: linear-gradient(180deg, #fffaf5 0%, #fff7ef 52%, #fffdfb 100%);
}

.ai-header {
  position: relative;
  flex-shrink: 0;
  margin: 18rpx 24rpx 14rpx;
  padding: 24rpx 26rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 205, 172, 0.88);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(91, 43, 111, 0.07);
}

.ai-header-pot,
.ai-header-leaf {
  position: absolute;
  pointer-events: none;
}

.ai-header-pot {
  right: -76rpx;
  bottom: -92rpx;
  width: 210rpx;
  height: 210rpx;
  opacity: 0.06;
}

.ai-header-leaf {
  right: 120rpx;
  top: 22rpx;
  width: 34rpx;
  height: 34rpx;
  opacity: 0.62;
}

.ai-profile {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.ai-avatar-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.ai-avatar {
  position: relative;
  z-index: 2;
  width: 88rpx;
  height: 88rpx;
  border: 2rpx solid #ffffff;
  border-radius: 50%;
  background: #fff7ef;
  box-shadow: 0 10rpx 24rpx rgba(255, 107, 26, 0.14);
  animation: avatar-breathe 3s ease-in-out infinite;
}

.avatar-pulse {
  position: absolute;
  inset: -6rpx;
  z-index: 1;
  border-radius: 50%;
  background: rgba(255, 107, 26, 0.16);
  animation: avatar-pulse 2s ease-in-out infinite;
}

.ai-avatar-wrap.speaking .ai-avatar { animation: avatar-speak 0.4s ease-in-out infinite; }
.ai-avatar-wrap.thinking .ai-avatar { animation: avatar-think 1.5s ease-in-out infinite; }

@keyframes avatar-breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.035); } }
@keyframes avatar-pulse { 0%, 100% { transform: scale(1); opacity: 0.38; } 50% { transform: scale(1.14); opacity: 0; } }
@keyframes avatar-speak { 0%, 100% { transform: rotate(0); } 25% { transform: rotate(-2deg); } 75% { transform: rotate(2deg); } }
@keyframes avatar-think { 0%, 100% { transform: rotate(0); } 25% { transform: rotate(-3deg); } 75% { transform: rotate(3deg); } }

.ai-info { flex: 1; min-width: 0; }
.ai-name-row { display: flex; align-items: center; gap: 10rpx; }
.ai-name { color: #2a1735; font-size: 32rpx; font-weight: 800; line-height: 1.25; }

.online-pill {
  height: 34rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  border-radius: 999rpx;
  color: #147a4d;
  background: #eafff2;
  font-size: 20rpx;
  font-weight: 700;
}

.online-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #2fb875; }
.ai-subtitle { display: block; margin-top: 6rpx; color: #6d536c; font-size: 23rpx; line-height: 1.45; }
.ai-actions { display: flex; align-items: center; gap: 12rpx; margin-top: 14rpx; }

.ask-recipe-btn,
.mini-action-btn,
.send-icon-btn {
  margin: 0;
  padding: 0;
  border: 0;
  line-height: 1;
}

.ask-recipe-btn::after,
.mini-action-btn::after,
.send-icon-btn::after { border: 0; }

.service-notice {
  margin: 8rpx 30rpx 22rpx 82rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: var(--color-primary-dark);
  background: var(--color-primary-lightest);
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  font-size: 24rpx;
}

.retry-btn {
  flex-shrink: 0;
  min-width: 104rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 20rpx;
  color: #ffffff;
  background: var(--color-accent);
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.retry-btn::after { border: 0; }

.ask-recipe-btn {
  min-width: 208rpx;
  height: 58rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ff466f 0%, #ff711f 100%);
  box-shadow: 0 8rpx 18rpx rgba(255, 90, 31, 0.2);
  font-size: 23rpx;
  font-weight: 800;
}

.ask-recipe-icon { width: 30rpx; height: 30rpx; filter: brightness(0) invert(1); }
.mini-action-btn { width: 84rpx; height: 58rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #ffd1b6; border-radius: 20rpx; background: #fff9f4; }
.mini-action-icon { width: 30rpx; height: 30rpx; }

.chat-messages { flex: 1; min-height: 0; box-sizing: border-box; padding: 0 0 16rpx; }

.recipe-ask-card {
  margin: 0 24rpx 16rpx;
  padding: 20rpx;
  border: 1rpx solid #ffc79f;
  border-radius: 24rpx;
  background: #ffffff;
}

.recipe-ask-head { display: flex; align-items: flex-start; gap: 12rpx; margin-bottom: 14rpx; }
.recipe-ask-icon { width: 44rpx; height: 44rpx; padding: 8rpx; border-radius: 16rpx; background: #fff7ef; }
.recipe-ask-title { display: block; color: #32163f; font-size: 27rpx; font-weight: 800; }
.recipe-ask-desc { display: block; margin-top: 2rpx; color: #806a7c; font-size: 21rpx; line-height: 1.35; }
.recipe-prompt-list { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10rpx; }

.recipe-prompt {
  min-width: 0;
  min-height: 84rpx;
  padding: 10rpx 6rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 1rpx solid #ffc79f;
  border-radius: 18rpx;
  background: #fffaf6;
  color: #32163f;
  font-size: 21rpx;
  font-weight: 700;
}

.recipe-prompt-icon { width: 32rpx; height: 32rpx; }

.quick-questions { margin: 0 24rpx 18rpx; }
.quick-label { display: block; margin: 0 6rpx 8rpx; color: #735f72; font-size: 21rpx; font-weight: 700; }
.quick-scroll { width: 100%; white-space: nowrap; }
.quick-list { display: inline-flex; gap: 10rpx; padding: 0 2rpx; }

.quick-item {
  min-height: 52rpx;
  max-width: 260rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
  border: 1rpx solid #ffc7a6;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5b2b6f;
  font-size: 22rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-row { position: relative; margin-bottom: 2rpx; }
.msg-tts-row { width: fit-content; min-height: 50rpx; margin: -10rpx 0 14rpx 110rpx; padding: 0 18rpx 0 12rpx; display: flex; align-items: center; gap: 6rpx; border: 1rpx solid #ffd7c2; border-radius: 999rpx; background: #fff9f4; }
.tts-icon { width: 28rpx; height: 28rpx; }
.tts-label { color: #f05c24; font-size: 22rpx; font-weight: 700; }

.suggestion-card { margin: 18rpx 24rpx; padding: 20rpx; display: flex; align-items: center; gap: 14rpx; border-radius: 22rpx; color: #ffffff; background: #5b2b6f; box-shadow: 0 12rpx 28rpx rgba(91, 43, 111, 0.16); }
.suggestion-icon { width: 48rpx; height: 48rpx; }
.suggestion-title { display: block; font-size: 26rpx; font-weight: 800; }
.suggestion-text { display: block; margin-top: 2rpx; color: rgba(255, 255, 255, 0.74); font-size: 21rpx; }

.typing-indicator { margin: 0 24rpx 12rpx 106rpx; min-height: 56rpx; display: flex; align-items: center; gap: 12rpx; }
.typing-dots { display: flex; gap: 7rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #ff6b1a; animation: typing-bounce 1.1s ease-in-out infinite; }
.dot:nth-child(2) { animation-delay: 0.18s; }
.dot:nth-child(3) { animation-delay: 0.36s; }
@keyframes typing-bounce { 0%, 70%, 100% { transform: translateY(0); opacity: 0.3; } 35% { transform: translateY(-7rpx); opacity: 1; } }
.typing-text { color: #806a7c; font-size: 22rpx; }

.chat-bottom-spacer { height: calc(env(safe-area-inset-bottom) + 270rpx); }

.input-area {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 148rpx);
  z-index: 80;
  box-sizing: border-box;
  padding: 10rpx;
  border: 1rpx solid #ffd1b6;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 10rpx 28rpx rgba(91, 43, 111, 0.1);
}

.input-row { display: flex; align-items: center; gap: 8rpx; }
.message-input { flex: 1; min-width: 0; height: 78rpx; padding: 0 24rpx; border-radius: 24rpx; background: #fff8f2; color: #2a1735; font-size: 26rpx; }
.action-btn { width: 68rpx; height: 68rpx; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: 22rpx; background: #fff8f2; }
.input-icon { width: 34rpx; height: 34rpx; }

.send-icon-btn { width: 76rpx; min-width: 76rpx; height: 76rpx; flex: 0 0 76rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #eadfdc; }
.send-icon-btn.active { background: linear-gradient(135deg, #ff466f 0%, #ff711f 100%); box-shadow: 0 8rpx 18rpx rgba(255, 90, 31, 0.22); }
.send-icon-btn.disabled { opacity: 0.52; }
.send-icon { width: 34rpx; height: 34rpx; }

.voice-btn.recording { background: #ff466f; animation: voice-recording 0.8s ease-in-out infinite; }
.voice-btn.recording .input-icon { filter: brightness(0) invert(1); }
@keyframes voice-recording { 0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 70, 111, 0.35); } 50% { transform: scale(1.06); box-shadow: 0 0 0 14rpx rgba(255, 70, 111, 0); } }

.recording-overlay { position: fixed; inset: 0; z-index: 999; display: flex; align-items: center; justify-content: center; background: rgba(42, 23, 53, 0.58); }
.recording-modal { width: 500rpx; box-sizing: border-box; padding: 42rpx; display: flex; flex-direction: column; align-items: center; gap: 18rpx; border-radius: 28rpx; background: #ffffff; box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.2); }
.recording-waves { height: 72rpx; display: flex; align-items: center; gap: 7rpx; }
.wave-bar { width: 8rpx; height: 36rpx; border-radius: 4rpx; background: linear-gradient(180deg, #ff466f 0%, #ff711f 100%); animation: wave-bounce 0.6s ease-in-out infinite alternate; }
@keyframes wave-bounce { 0% { height: 18rpx; } 100% { height: 64rpx; } }
.recording-text { color: #2a1735; font-size: 29rpx; font-weight: 800; }
.recording-result { max-width: 420rpx; padding: 10rpx 18rpx; border: 1rpx solid #ffd1b6; border-radius: 14rpx; color: #f05c24; background: #fff7ef; font-size: 26rpx; line-height: 1.5; text-align: center; }
.recording-hint { color: #806a7c; font-size: 21rpx; }

@media (max-width: 360px) {
  .ai-header { padding: 20rpx; }
  .ai-avatar-wrap, .ai-avatar { width: 78rpx; height: 78rpx; }
  .ask-recipe-btn { min-width: 184rpx; }
  .message-input { padding: 0 18rpx; }
  .send-icon-btn { width: 72rpx; min-width: 72rpx; flex-basis: 72rpx; height: 72rpx; }
}
