.page-chat {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(circle at 18% 10%, rgba(255,107,26,0.16), transparent 220rpx),
    linear-gradient(180deg, #fff7f0 0%, #ffffff 100%);
}

.ai-header {
  flex-shrink: 0;
  padding: 26rpx 28rpx;
  background: rgba(255,255,255,0.88);
  border-bottom: 1rpx solid rgba(255,215,194,0.9);
  backdrop-filter: blur(16rpx);
}

.ai-profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.ai-avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 24rpx rgba(91,43,111,0.12);
}

.ai-info {
  flex: 1;
}

.ai-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ai-name {
  color: #2a1735;
  font-size: 34rpx;
  font-weight: 900;
}

.online-pill {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #0f7a45;
  background: #effff4;
  font-size: 20rpx;
  font-weight: 850;
}

.ai-subtitle {
  display: block;
  margin-top: 4rpx;
  color: #a78a96;
  font-size: 23rpx;
}

.chat-messages {
  flex: 1;
  padding: 24rpx 0;
}

.suggestion-card {
  margin: 24rpx 28rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #2a1735;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #fff;
  box-shadow: 0 18rpx 42rpx rgba(42,23,53,0.18);
}

.suggestion-icon {
  width: 58rpx;
  height: 58rpx;
}

.suggestion-title {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
}

.suggestion-text {
  display: block;
  margin-top: 4rpx;
  color: rgba(255,255,255,0.72);
  font-size: 23rpx;
}

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 32rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff6b1a;
  animation: typing-bounce 1.1s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.18s; }
.dot:nth-child(3) { animation-delay: 0.36s; }

@keyframes typing-bounce {
  0%, 70%, 100% { transform: translateY(0); opacity: 0.35; }
  35% { transform: translateY(-8rpx); opacity: 1; }
}

.typing-text {
  color: #a78a96;
  font-size: 24rpx;
}

.quick-questions {
  flex-shrink: 0;
  padding: 0 28rpx 22rpx;
}

.quick-label {
  display: block;
  margin-bottom: 14rpx;
  color: #6d536c;
  font-size: 24rpx;
  font-weight: 850;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-item {
  max-width: 100%;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #ffd7c2;
  color: #5b2b6f;
  font-size: 24rpx;
  font-weight: 780;
}

.input-area {
  flex-shrink: 0;
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.94);
  border-top: 1rpx solid rgba(255,215,194,0.9);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.message-input {
  flex: 1;
  height: 78rpx;
  padding: 0 28rpx;
  border-radius: 26rpx;
  background: #fff1e8;
  color: #2a1735;
  font-size: 28rpx;
}

.action-btn {
  width: 78rpx;
  height: 78rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff1e8;
  color: #5b2b6f;
  font-weight: 900;
}

.voice-mark {
  font-size: 20rpx;
}

.send-mark {
  font-size: 34rpx;
  transform: translateX(1rpx);
}

.send-btn.active {
  color: #fff;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 10rpx 24rpx rgba(255,107,26,0.24);
}
