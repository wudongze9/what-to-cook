  backdrop-filter: blur(18rpx);
}

.message-input {
  height: 82rpx;
  border-radius: 26rpx;
  background: #fff7ef;
}

.action-btn {
  width: 82rpx;
  height: 82rpx;
  border-radius: 26rpx;
}

.send-btn.active {
  box-shadow: 0 14rpx 28rpx rgba(255, 90, 31, 0.26);
}
