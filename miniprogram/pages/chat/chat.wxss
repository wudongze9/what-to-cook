.page-chat {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(circle at 18% 10%, rgba(255,107,26,0.16), transparent 220rpx),
    radial-gradient(circle at 88% 18%, rgba(47,184,117,0.10), transparent 220rpx),
    linear-gradient(180deg, #fffbeb 0%, #fff7f0 52%, #ffffff 100%);
}

/* ==================== 头部数字人 ==================== */

.ai-header {
  flex-shrink: 0;
  padding: 26rpx 28rpx;
  background: rgba(255,255,255,0.88);
  border-bottom: 1rpx solid rgba(255,215,194,0.9);
  backdrop-filter: blur(16rpx);
}

.ai-profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.ai-avatar-wrap {
  position: relative;
  width: 86rpx;
  height: 86rpx;
  flex-shrink: 0;
}

.ai-avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 24rpx rgba(91,43,111,0.12);
  position: relative;
  z-index: 2;
  animation: avatar-breathe 3s ease-in-out infinite;
}

/* 呼吸光圈 */
.avatar-pulse {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  right: -6rpx;
  bottom: -6rpx;
  border-radius: 32rpx;
  background: rgba(255, 107, 26, 0.2);
  animation: avatar-pulse 2s ease-in-out infinite;
  z-index: 1;
}

/* 说话时头像动效 */
.ai-avatar-wrap.speaking .ai-avatar {
  animation: avatar-speak 0.4s ease-in-out infinite;
}

.ai-avatar-wrap.speaking .avatar-pulse {
  background: rgba(255, 107, 26, 0.35);
  animation: avatar-pulse 0.6s ease-in-out infinite;
}

/* 思考时头像动效 */
.ai-avatar-wrap.thinking .ai-avatar {
  animation: avatar-think 1.5s ease-in-out infinite;
}

@keyframes avatar-breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.04); }
}

@keyframes avatar-pulse {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.15); opacity: 0; }
}

@keyframes avatar-speak {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.05) rotate(-2deg); }
  75% { transform: scale(1.05) rotate(2deg); }
}

@keyframes avatar-think {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-3deg); }
  75% { transform: rotate(3deg); }
}

.ai-info {
  flex: 1;
  min-width: 0;
}

.ai-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ai-name {
  color: #2a1735;
  font-size: 34rpx;
  font-weight: 900;
}

.online-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #0f7a45;
  background: #effff4;
  font-size: 20rpx;
  font-weight: 850;
}

.online-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2fb975;
  animation: online-blink 1.5s ease-in-out infinite;
}

@keyframes online-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.ai-subtitle {
  display: block;
  margin-top: 4rpx;
  color: #a78a96;
  font-size: 23rpx;
}

.ai-skills {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.skill-chip {
  font-size: 18rpx;
  font-weight: 700;
  color: #ff6b1a;
  background: rgba(255, 107, 26, 0.08);
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
}

/* ==================== 消息列表 ==================== */

.chat-messages {
  flex: 1;
  padding: 24rpx 0;
}

.msg-row {
  position: relative;
}

.msg-tts-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin: -12rpx 0 16rpx 110rpx;
  padding: 6rpx 16rpx 6rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #ffe0cd;
  width: fit-content;
}

.tts-icon {
  width: 26rpx;
  height: 26rpx;
}

.tts-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #ff6b1a;
}

.suggestion-card {
  margin: 24rpx 28rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2a1735 0%, #9a3412 100%);
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #fff;
  box-shadow: 0 18rpx 42rpx rgba(42,23,53,0.18);
}

.suggestion-icon {
  width: 58rpx;
  height: 58rpx;
}

.suggestion-title {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
}

.suggestion-text {
  display: block;
  margin-top: 4rpx;
  color: rgba(255,255,255,0.72);
  font-size: 23rpx;
}

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 32rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff6b1a;
  animation: typing-bounce 1.1s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.18s; }
.dot:nth-child(3) { animation-delay: 0.36s; }

@keyframes typing-bounce {
  0%, 70%, 100% { transform: translateY(0); opacity: 0.35; }
  35% { transform: translateY(-8rpx); opacity: 1; }
}

.typing-text {
  color: #a78a96;
  font-size: 24rpx;
}

/* ==================== 快捷问题 ==================== */

.quick-questions {
  flex-shrink: 0;
  padding: 0 28rpx 22rpx;
}

.quick-label {
  display: block;
  margin-bottom: 14rpx;
  color: #6d536c;
  font-size: 24rpx;
  font-weight: 850;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-item {
  max-width: 100%;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffaf6 100%);
  border: 2rpx solid #ffd7c2;
  color: #5b2b6f;
  font-size: 24rpx;
  font-weight: 780;
}

/* ==================== 输入区 ==================== */

.input-area {
  flex-shrink: 0;
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.96);
  border-top: 1rpx solid rgba(255,215,194,0.9);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.message-input {
  flex: 1;
  height: 78rpx;
  padding: 0 28rpx;
  border-radius: 26rpx;
  background: #fff7ed;
  color: #2a1735;
  font-size: 28rpx;
}

.action-btn {
  width: 78rpx;
  height: 78rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff7ed;
  color: #5b2b6f;
  font-weight: 900;
}

.input-icon {
  width: 46rpx;
  height: 46rpx;
}

.send-btn.active {
  color: #fff;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 10rpx 24rpx rgba(255,107,26,0.24);
}

/* 录音按钮按下状态 */
.voice-btn.recording {
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  animation: voice-recording 0.8s ease-in-out infinite;
}

.voice-btn.recording .input-icon {
  filter: brightness(0) invert(1);
}

@keyframes voice-recording {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 61, 110, 0.4); }
  50% { transform: scale(1.08); box-shadow: 0 0 0 16rpx rgba(255, 61, 110, 0); }
}

/* ==================== 录音遮罩 ==================== */

.recording-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 23, 53, 0.6);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.recording-modal {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 48rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.2);
}

.recording-waves {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 80rpx;
}

.wave-bar {
  width: 8rpx;
  height: 40rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #ff3d6e 0%, #ff7a1a 100%);
  animation: wave-bounce 0.6s ease-in-out infinite alternate;
}

@keyframes wave-bounce {
  0% { height: 20rpx; }
  100% { height: 70rpx; }
}

.recording-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #2a1735;
}

.recording-hint {
  font-size: 22rpx;
  color: #a78a96;
}

/* Reference replica polish */
.page-chat {
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(env(safe-area-inset-bottom) + 132rpx);
  background:
    radial-gradient(circle at 86% 16%, rgba(255, 126, 32, 0.13), transparent 250rpx),
    radial-gradient(circle at 16% 42%, rgba(255, 61, 110, 0.08), transparent 220rpx),
    linear-gradient(180deg, #fffaf5 0%, #fff5ec 56%, #ffffff 100%);
  overflow: hidden;
}

.ai-header {
  position: relative;
  margin: 26rpx 24rpx 22rpx;
  padding: 34rpx 34rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255,255,255,0.84);
  background:
    radial-gradient(circle at 88% 48%, rgba(255, 126, 32, 0.16), transparent 170rpx),
    linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.80) 100%);
  box-shadow: 0 24rpx 58rpx rgba(91, 43, 111, 0.11);
  overflow: hidden;
}

.ai-header-pot,
.ai-header-leaf {
  position: absolute;
  pointer-events: none;
}

.ai-header-pot {
  right: -52rpx;
  bottom: -78rpx;
  width: 250rpx;
  height: 250rpx;
  opacity: 0.13;
}

.ai-header-leaf {
  right: 170rpx;
  top: 28rpx;
  width: 42rpx;
  height: 42rpx;
  opacity: 0.72;
}

.ai-profile {
  position: relative;
  z-index: 1;
  gap: 26rpx;
}

.ai-avatar-wrap {
  width: 126rpx;
  height: 126rpx;
}

.ai-avatar {
  width: 126rpx;
  height: 126rpx;
  border-radius: 50%;
  background: #fff7ef;
  border: 3rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 18rpx 38rpx rgba(255, 107, 26, 0.16);
}

.avatar-pulse {
  border-radius: 50%;
  background: rgba(255, 107, 26, 0.16);
}

.ai-name {
  font-size: 42rpx;
  color: #32163f;
}

.online-pill {
  height: 42rpx;
  padding: 0 18rpx;
  color: #14925a;
  background: #eafff1;
  font-size: 24rpx;
}

.ai-subtitle {
  margin-top: 10rpx;
  color: #765f75;
  font-size: 27rpx;
  line-height: 1.45;
}

.ai-skills {
  margin-top: 18rpx;
  gap: 14rpx;
}

.skill-chip {
  padding: 9rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #ff5a1f;
  background: linear-gradient(180deg, #fff7ef 0%, #ffffff 100%);
  border: 1rpx solid rgba(255, 215, 194, 0.92);
}

.chat-messages {
  padding: 8rpx 0 22rpx;
  box-sizing: border-box;
}

.msg-row {
  margin-bottom: 8rpx;
}

.msg-tts-row {
  min-height: 58rpx;
  margin: -8rpx 0 18rpx 116rpx;
  padding: 0 20rpx 0 14rpx;
  background: #fffaf6;
  border-color: rgba(255, 215, 194, 0.95);
  box-shadow: 0 8rpx 20rpx rgba(91, 43, 111, 0.06);
}

.tts-icon {
  width: 32rpx;
  height: 32rpx;
}

.tts-label {
  font-size: 25rpx;
}

.quick-questions {
  padding: 0 24rpx 18rpx;
}

.quick-list {
  flex-wrap: nowrap;
  overflow: hidden;
}

.quick-item {
  max-width: 212rpx;
  min-height: 58rpx;
  padding: 10rpx 20rpx;
  display: flex;
  align-items: center;
  font-size: 23rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-shadow: 0 8rpx 18rpx rgba(91, 43, 111, 0.05);
