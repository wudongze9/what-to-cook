.page-videos {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff7f0 0%, #ffffff 78%);
  padding-bottom: calc(env(safe-area-inset-bottom) + 150rpx);
}

.video-hero {
  margin: 30rpx 28rpx 24rpx;
  padding: 34rpx;
  min-height: 220rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 84% 18%, rgba(255,255,255,0.32), transparent 130rpx),
    linear-gradient(135deg, #2a1735 0%, #5b2b6f 46%, #ff3d6e 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 20rpx 52rpx rgba(91,43,111,0.20);
}

.hero-copy {
  width: 450rpx;
}

.hero-kicker {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.82);
  font-size: 20rpx;
  font-weight: 800;
}

.page-title {
  display: block;
  margin-top: 20rpx;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 900;
}

.page-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  color: rgba(255,255,255,0.74);
  line-height: 1.55;
}

.hero-icon {
  width: 116rpx;
  height: 116rpx;
}

.category-bar {
  white-space: nowrap;
  padding: 0 28rpx 24rpx;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  height: 62rpx;
  padding: 0 26rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #ffd7c2;
  color: #5b2b6f;
  font-size: 24rpx;
  font-weight: 800;
}

.category-pill.active {
  color: #fff;
  border-color: transparent;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 12rpx 28rpx rgba(255,107,26,0.24);
}

.featured-section {
  padding: 0 28rpx;
}

.section-heading,
.section-header {
  padding: 8rpx 28rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.featured-section .section-heading {
  padding-left: 0;
  padding-right: 0;
}

.section-title {
  color: #2a1735;
  font-size: 32rpx;
  font-weight: 900;
}

.section-note,
.video-count {
  color: #a78a96;
  font-size: 23rpx;
  font-weight: 700;
}

.video-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 28rpx;
}

.grid-item {
  width: calc(50% - 10rpx);
}

.empty-state {
  margin: 40rpx 28rpx;
  padding: 56rpx 32rpx;
  border-radius: 32rpx;
  background: #fff;
  border: 2rpx dashed #ffd7c2;
  text-align: center;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
}

.empty-title {
  display: block;
  margin-top: 18rpx;
  color: #2a1735;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-text {
  display: block;
  margin-top: 8rpx;
  color: #a78a96;
  font-size: 24rpx;
}

.empty-btn {
  margin-top: 26rpx;
  width: 260rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #ff6b1a;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
}

.empty-btn::after {
  border: none;
}

.bottom-link {
  margin: 34rpx 28rpx 0;
  height: 82rpx;
  border-radius: 26rpx;
  background: #fff1e8;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #ff6b1a;
  font-size: 26rpx;
  font-weight: 850;
}

.link-icon {
  width: 38rpx;
  height: 38rpx;
}
