.page-steps {
  min-height: 100vh;
  background:
    radial-gradient(circle at 88% 4%, rgba(255,107,26,0.16), transparent 190rpx),
    radial-gradient(circle at 12% 18%, rgba(47,184,117,0.14), transparent 190rpx),
    linear-gradient(180deg, #fffbeb 0%, #fff7f0 58%, #ffffff 100%);
  padding: 0 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 250rpx);
}

/* 进度条 */
.progress-bar {
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text, #3D2B1F);
}

.progress-percent {
  font-size: 24rpx;
  color: var(--color-primary, #F28C38);
  font-weight: 600;
}

.progress-track {
  height: 12rpx;
  background: var(--color-border, #F0DCC8);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 72%, #2fb875 100%);
  border-radius: 999rpx;
  transition: width 0.5s ease;
}

.current-step-card {
  margin-bottom: 24rpx;
  padding: 26rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #5b2b6f 0%, #ff3d6e 56%, #ff7a1a 100%);
  color: #fff;
  box-shadow: 0 20rpx 54rpx rgba(255,107,26,0.24);
  overflow: hidden;
  position: relative;
}

.current-step-card::after {
  content: '';
  position: absolute;
  right: -64rpx;
  top: -68rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.16);
}

.current-copy {
  position: relative;
  z-index: 1;
}

.current-kicker {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
  font-size: 21rpx;
  font-weight: 850;
}

.current-title {
  display: block;
  margin-top: 14rpx;
  font-size: 38rpx;
  font-weight: 950;
  line-height: 1.2;
  word-break: break-all;
}

.current-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: rgba(255,255,255,0.86);
  word-break: break-all;
}

.timer-card {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.94);
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
}

.timer-icon {
  width: 58rpx;
  height: 58rpx;
  flex-shrink: 0;
}

.timer-text {
  color: #2a1735;
  font-size: 42rpx;
  font-weight: 950;
  font-variant-numeric: tabular-nums;
  min-width: 126rpx;
}

.timer-actions {
  grid-column: 1 / -1;
  width: 100%;
  margin-left: 0;
  display: flex;
  gap: 12rpx;
  box-sizing: border-box;
}

.timer-btn {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  margin: 0;
  padding: 0 18rpx;
  border: none;
  border-radius: 999rpx;
  background: #fff1e8;
  color: #5b2b6f;
  font-size: 22rpx;
  font-weight: 850;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.timer-btn::after {
  border: none;
}

.timer-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 8rpx 18rpx rgba(255, 90, 31, 0.22);
}

.timer-btn-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 4rpx;
}

/* 食材清单 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  gap: 18rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 16rpx;
}

.shopping-link {
  color: #2fb875;
  font-size: 23rpx;
  font-weight: 850;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text, #3D2B1F);
}

.check-count {
  font-size: 24rpx;
  color: var(--color-primary, #F28C38);
  font-weight: 600;
}

.ingredient-checklist {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 68rpx;
  padding: 10rpx 12rpx;
  border-radius: 22rpx;
  background: #fff7f0;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border, #F0DCC8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #FFFFFF;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #2fb875;
  border-color: #2fb875;
}

.check-icon {
  width: 46rpx;
  height: 46rpx;
  flex-shrink: 0;
}

.check-item.checked .check-name {
  text-decoration: line-through;
  color: var(--color-text-tertiary, #A89288);
}

.check-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--color-text, #3D2B1F);
  line-height: 1.25;
  word-break: break-all;
}

.check-amount {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 600;
  color: #ff6b1a;
  flex-shrink: 0;
}

/* 步骤时间线 */
.steps-timeline {
  margin-top: 32rpx;
}

/* 配图 */
.step-image {
  margin: 32rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.step-img {
  width: 100%;
  height: 300rpx;
}

.step-img-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
  color: #FFFFFF;
  font-size: 24rpx;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 18rpx);
  z-index: 40;
  margin-top: 0;
  padding: 18rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(255,215,194,0.9);
  box-shadow: 0 18rpx 54rpx rgba(42,23,53,0.16);
  backdrop-filter: blur(18rpx);
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.btn-prev, .btn-next {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  text-align: center;
  padding: 0 18rpx;
  overflow: hidden;
}

.btn-prev::after, .btn-next::after {
  border: none;
}

.btn-prev {
  background: var(--color-surface, #FFFFFF);
  color: var(--color-text-secondary, #7A6258);
  border: 2rpx solid var(--color-border, #F0DCC8);
}

.btn-prev.disabled {
  opacity: 0.4;
}

.btn-next {
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  color: #FFFFFF;
  box-shadow: 0 10rpx 28rpx rgba(255, 107, 26, 0.28);
}

.link-row {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 18rpx;
  gap: 20rpx;
  flex-wrap: wrap;
}

.link-text {
  font-size: 26rpx;
  color: var(--color-primary, #F28C38);
  line-height: 1.3;
}

.link-divider {
  color: var(--color-border, #F0DCC8);
}
