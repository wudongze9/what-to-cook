.page-result {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff7f0 0%, #ffffff 78%);
  padding-bottom: calc(env(safe-area-inset-bottom) + 220rpx);
  opacity: 0;
  animation: fadeIn 0.5s ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.hero-section {
  position: relative;
  width: 100%;
  height: 500rpx;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  animation: heroZoom 8s ease-in-out infinite alternate;
}

@keyframes heroZoom {
  from { transform: scale(1); }
  to { transform: scale(1.08); }
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(to top, var(--color-bg, #FFF9F3), transparent);
}

.dish-info {
  padding: 0 32rpx;
  margin-top: -80rpx;
  position: relative;
  z-index: 10;
  opacity: 0;
  animation: fadeInUp 0.6s ease 0.15s forwards;
}

.info-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 34rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 54rpx rgba(91,43,111,0.14);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255,255,255,0.6);
}

.info-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.dish-name {
  flex: 1;
  min-width: 0;
  font-size: 48rpx;
  font-weight: 800;
  color: #2a1735;
  line-height: 1.2;
  word-break: break-all;
}

.category-tag {
  flex-shrink: 0;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 999rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(242, 140, 56, 0.25);
}

.favorite-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--color-surface, #FFFFFF);
  border: 2rpx solid var(--color-border, #F0DCC8);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary, #A89288);
  margin-bottom: 20rpx;
  transition: all 0.2s;
}

.favorite-btn.active {
  background: #fff1e8;
  border-color: #ff3d6e;
  color: #ff3d6e;
}

.fav-icon {
  font-size: 28rpx;
}

.dish-desc {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary, #7A6258);
  line-height: 1.7;
  word-break: break-all;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.dish-tag {
  font-size: 20rpx;
  font-weight: 700;
  color: #ff6b1a;
  background: rgba(255, 107, 26, 0.08);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

/* 食材卡 */
.ingredients-card {
  margin: 28rpx 32rpx 0;
  opacity: 0;
  animation: fadeInUp 0.6s ease 0.25s forwards;
  padding: 28rpx 24rpx;
}

.card-label-wrap,
.section-label-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.label-img {
  width: 36rpx;
  height: 36rpx;
}

.card-label {
  font-size: 26rpx;
  color: var(--color-text-tertiary, #A89288);
  font-weight: 600;
  flex: 1;
}

.ingredient-count {
  font-size: 22rpx;
  color: #ff6b1a;
  font-weight: 700;
  background: rgba(255, 107, 26, 0.08);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

/* 食材组合 - 2 列水平卡片 */
.ingredient-tags {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.ingredient-tag {
  min-width: 0;
  min-height: 118rpx;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: linear-gradient(180deg, #fffaf6 0%, #ffffff 100%);
  border: 2rpx solid #ffd7c2;
  box-shadow: inset 0 -4rpx 0 rgba(255, 107, 26, 0.06);
  opacity: 0;
  animation: popIn 0.35s ease forwards;
}

.ingredient-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 6rpx 10rpx rgba(91,43,111,0.10));
}

.ingredient-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ingredient-name {
  font-size: 26rpx;
  font-weight: 800;
  color: #2a1735;
  line-height: 1.25;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

.ingredient-amount {
  font-size: 21rpx;
  font-weight: 600;
  color: #ff6b1a;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 可替换食材面板 */
.substitute-panel {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx dashed rgba(255, 215, 194, 0.8);
}

.substitute-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #6d536c;
  font-size: 24rpx;
  font-weight: 850;
  margin-bottom: 16rpx;
}

.substitute-list {
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 6rpx;
}

.substitute-group {
  width: 232rpx;
  min-height: 170rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #fffaf6;
  border: 1rpx solid #ffe0cd;
}

.substitute-source-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.substitute-source-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.substitute-source {
  min-width: 0;
  font-size: 24rpx;
  font-weight: 800;
  color: #2a1735;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.substitute-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  white-space: normal;
}

.substitute-chip {
  max-width: 94rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #ffd7c2;
  color: #5b2b6f;
  font-size: 22rpx;
  font-weight: 700;
  overflow: hidden;
}

.substitute-chip text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.substitute-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.substitute-empty {
  font-size: 22rpx;
  color: #b8a8a0;
  font-style: italic;
  white-space: normal;
  line-height: 1.35;
}

@keyframes popIn {
  from { opacity: 0; transform: scale(0.7); }
  to { opacity: 1; transform: scale(1); }
}

/* 信息行 */
.info-row {
  display: flex;
  padding: 0 32rpx;
  gap: 16rpx;
  margin-top: 20rpx;
  opacity: 0;
  animation: fadeInUp 0.6s ease 0.35s forwards;
}

.info-item {
  flex: 1;
  background: var(--color-surface, #FFFFFF);
  border-radius: 20rpx;
  min-width: 0;
  padding: 22rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border: 1rpx solid var(--color-border, #F0DCC8);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: transform 0.2s;
}

.info-item:active {
  transform: translateY(-4rpx);
}

.info-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.info-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #A89288);
}

.info-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text, #3D2B1F);
  max-width: 100%;
  text-align: center;
  line-height: 1.2;
  word-break: break-all;
}

/* 备选菜品 */
.alternatives-section {
  padding: 0 32rpx;
  margin-top: 28rpx;
  opacity: 0;
  animation: fadeInUp 0.6s ease 0.45s forwards;
}

.section-label {
  font-size: 26rpx;
  color: var(--color-text-tertiary, #A89288);
  font-weight: 600;
}

.alternatives-scroll {
  white-space: nowrap;
}

.alternatives-list {
  display: inline-flex;
  gap: 16rpx;
}

.alternative-item {
  width: 204rpx;
  background: var(--color-surface, #FFFFFF);
  border: 1rpx solid var(--color-border, #F0DCC8);
  border-radius: 20rpx;
  padding: 22rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  opacity: 0;
  animation: slideInRight 0.45s ease forwards;
}

.alternative-item:active {
  background: var(--color-primary-lightest, #FFF3E4);
  border-color: var(--color-primary, #F28C38);
}

.alt-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text, #3D2B1F);
  text-align: center;
  max-width: 100%;
  line-height: 1.25;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.alt-meta {
  font-size: 20rpx;
  color: var(--color-text-tertiary, #A89288);
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 操作按钮 */
.action-buttons {
  padding: 34rpx 32rpx calc(env(safe-area-inset-bottom) + 18rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  opacity: 0;
  animation: fadeInUp 0.6s ease 0.55s forwards;
}

.action-buttons .btn-primary,
.action-buttons .btn-outline,
.action-buttons .btn-secondary {
  width: 520rpx;
  max-width: 82vw;
  min-height: 96rpx;
  line-height: 1.2;
  padding: 18rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: normal;
  word-break: keep-all;
  text-align: center;
}

.btn-secondary {
  border: none;
  border-radius: 999rpx;
  background: #fffaf6;
  color: #5b2b6f;
  font-size: 28rpx;
  font-weight: 850;
  box-shadow: 0 12rpx 32rpx rgba(91,43,111,0.08);
}

.btn-secondary::after {
  border: none;
}

.btn-icon {
  width: 42rpx;
  height: 42rpx;
  margin-right: 10rpx;
}

.btn-glow {
  position: relative;
  overflow: hidden;
  box-shadow: 0 14rpx 38rpx rgba(255, 107, 26, 0.35);
}

.btn-glow::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
  animation: shine 2.8s infinite;
}

.link-text {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-primary, #F28C38);
  margin-top: 8rpx;
  font-weight: 500;
  max-width: 88vw;
  line-height: 1.35;
  text-align: center;
}

.link-text text {
  min-width: 0;
  word-break: keep-all;
}

.link-icon-img {
  width: 34rpx;
  height: 34rpx;
}

@keyframes shine {
  0% { left: -100%; }
  60%, 100% { left: 160%; }
}

/* 小贴士 */
.tips-card {
  margin: 32rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF3E4 100%);
  border-color: var(--color-primary-light, #F9B77A);
  opacity: 0;
  animation: fadeInUp 0.6s ease 0.65s forwards;
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tips-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-primary, #F28C38);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(242, 140, 56, 0.25);
}

.tips-icon-img {
  width: 30rpx;
  height: 30rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text, #3D2B1F);
}

.tips-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #7A6258);
  line-height: 1.7;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideInRight {
  from { opacity: 0; transform: translateX(30rpx); }
  to { opacity: 1; transform: translateX(0); }
}
