.video-player-page {
  background: #000;
  min-height: 100vh;
}

.video-container {
  width: 100%;
  background: #000;
}

.player {
  width: 100%;
  height: 420rpx;
}

/* 视频详情 */
.video-detail {
  background: #1a1a1a;
  padding: 24rpx 32rpx;
}

.video-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.video-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.meta-chef {
  font-size: 24rpx;
  color: #F28C38;
}

.meta-views {
  font-size: 24rpx;
  color: #999;
}

.video-desc {
  font-size: 26rpx;
  color: #ccc;
  line-height: 1.6;
}

/* 相关推荐 */
.related-section {
  padding: 32rpx;
  background: #1a1a1a;
}

.related-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.related-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #2a2a2a;
}

.related-cover {
  width: 160rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.related-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.related-name {
  font-size: 26rpx;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.related-chef {
  font-size: 22rpx;
  color: #999;
}