.video-player-page { background: #000; min-height: 100vh; }
.dish-header { padding: 32rpx 32rpx 16rpx; background: #1a1a1a; }
.dish-title { display: block; font-size: 36rpx; font-weight: 600; color: #fff; margin-bottom: 8rpx; }
.dish-count { display: block; font-size: 24rpx; color: #999; }
.video-list { padding: 16rpx 32rpx 32rpx; display: flex; flex-direction: column; gap: 24rpx; }
.video-card { background: #1a1a1a; border-radius: 16rpx; overflow: hidden; }
.card-cover { position: relative; width: 100%; height: 360rpx; background: #2a2a2a; }
.cover-img { width: 100%; height: 100%; }
.cover-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #2a2a2a, #3a3a3a); }
.placeholder-text { font-size: 40rpx; color: #666; font-weight: 500; }
.duration-badge { position: absolute; right: 16rpx; bottom: 16rpx; padding: 4rpx 12rpx; background: rgba(0,0,0,0.7); color: #fff; font-size: 22rpx; border-radius: 6rpx; }
.source-badge { position: absolute; left: 16rpx; top: 16rpx; padding: 4rpx 12rpx; background: rgba(242,140,56,0.9); color: #fff; font-size: 22rpx; border-radius: 6rpx; }
.card-info { padding: 20rpx 24rpx; }
.card-title { display: block; font-size: 30rpx; font-weight: 500; color: #fff; line-height: 1.4; margin-bottom: 12rpx; }
.card-meta { display: flex; gap: 20rpx; margin-bottom: 8rpx; }
.card-author, .card-cat { font-size: 24rpx; color: #999; }
.card-desc { display: block; font-size: 24rpx; color: #777; line-height: 1.5; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.empty-state { padding: 160rpx 64rpx; display: flex; flex-direction: column; align-items: center; background: #1a1a1a; min-height: 60vh; }
.empty-icon { font-size: 96rpx; margin-bottom: 32rpx; }
.empty-title { font-size: 32rpx; color: #fff; margin-bottom: 16rpx; }
.empty-desc { font-size: 26rpx; color: #999; }
.video-container { width: 100%; background: #000; }
.player { width: 100%; height: 420rpx; }
.video-detail { background: #1a1a1a; padding: 24rpx 32rpx; }
.video-title { font-size: 32rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 12rpx; line-height: 1.4; }
.video-meta { display: flex; gap: 24rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.meta-author { font-size: 24rpx; color: #F28C38; }
.meta-source { font-size: 24rpx; color: #F28C38; }
.meta-duration { font-size: 24rpx; color: #999; }
.video-desc { font-size: 26rpx; color: #ccc; line-height: 1.6; }
.video-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.tag-item { font-size: 22rpx; color: #F28C38; background: rgba(242,140,56,0.15); padding: 4rpx 16rpx; border-radius: 20rpx; }
.external-cover { position: relative; width: 100%; height: 420rpx; background: #2a2a2a; }
.cover-placeholder-lg { height: 420rpx; }
.placeholder-text-lg { font-size: 56rpx; color: #666; font-weight: 500; }
.play-overlay { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(0,0,0,0.4); }
.play-btn { width: 120rpx; height: 120rpx; border-radius: 60rpx; background: rgba(242,140,56,0.9); color: #fff; font-size: 56rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 16rpx; text-indent: 8rpx; }
.play-text { font-size: 26rpx; color: #fff; }
.source-badge-lg { font-size: 24rpx; padding: 6rpx 16rpx; }
.external-actions { padding: 24rpx 32rpx 14rpx; background: #1a1a1a; display: flex; align-items: center; gap: 16rpx; }
.external-open-btn,
.external-copy-btn { height: 88rpx; min-width: 0; margin: 0; padding: 0 22rpx; box-sizing: border-box; display: flex; align-items: center; justify-content: center; gap: 10rpx; border-radius: 24rpx; font-weight: 750; line-height: 1; }
.external-open-btn::after,
.external-copy-btn::after { border: 0; }
.external-open-btn { flex: 1; color: #ffffff; background: linear-gradient(135deg, #ff6b1a 0%, #f28c38 100%); font-size: 28rpx; box-shadow: 0 10rpx 26rpx rgba(242, 140, 56, 0.25); }
.external-copy-btn { width: 180rpx; flex: 0 0 180rpx; color: #f5a45d; background: #242424; border: 1rpx solid #4a3a2d; font-size: 26rpx; }
.external-open-icon,
.external-copy-icon { width: 32rpx; height: 32rpx; flex-shrink: 0; }
.external-open-icon { filter: brightness(0) invert(1); }
.external-open-btn:active,
.external-copy-btn:active { opacity: 0.82; transform: scale(0.98); }
.external-tip { padding: 8rpx 32rpx 24rpx; background: #1a1a1a; }
.tip-text { font-size: 22rpx; color: #666; line-height: 1.5; }
.related-section { padding: 32rpx; background: #1a1a1a; }
.related-title { font-size: 28rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 20rpx; }
.related-list { display: flex; flex-direction: column; gap: 16rpx; }
.related-item { display: flex; align-items: center; gap: 16rpx; padding: 12rpx; border-radius: 12rpx; background: #2a2a2a; }
.related-cover { width: 160rpx; height: 100rpx; border-radius: 8rpx; flex-shrink: 0; }
.related-cover-placeholder { display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: #666; background: #3a3a3a; }
.related-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.related-name { font-size: 26rpx; color: #fff; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.related-author { font-size: 22rpx; color: #999; }
.native-controls { margin: 18rpx 24rpx 0; display: flex; align-items: center; gap: 10rpx; }
.skip-btn { min-height: 64rpx; padding: 0 16rpx; flex-shrink: 0; display: flex; align-items: center; border: 1rpx solid #ffd1b6; border-radius: 18rpx; color: #5b2b6f; background: #ffffff; font-size: 21rpx; font-weight: 700; }
.rate-list { flex: 1; min-width: 0; display: flex; justify-content: center; gap: 6rpx; }
.rate-item { min-width: 48rpx; height: 54rpx; padding: 0 6rpx; display: flex; align-items: center; justify-content: center; border-radius: 14rpx; color: #806a7c; background: #fff7ef; font-size: 19rpx; font-weight: 700; }
.rate-item.active { color: #ffffff; background: #ff5a1f; }
.play-progress { display: block; margin: 10rpx 28rpx 0; color: #806a7c; font-size: 21rpx; font-variant-numeric: tabular-nums; text-align: right; }
.external-tip { display: flex; align-items: flex-start; gap: 12rpx; }
.tip-icon { width: 34rpx; height: 34rpx; flex-shrink: 0; }
.tip-text { flex: 1; }

@media (max-width: 360px) {
  .native-controls { flex-wrap: wrap; }
  .rate-list { order: 3; flex-basis: 100%; }
  .skip-btn { flex: 1; justify-content: center; }
  .external-actions { padding-left: 24rpx; padding-right: 24rpx; gap: 12rpx; }
  .external-copy-btn { width: 156rpx; flex-basis: 156rpx; }
}
