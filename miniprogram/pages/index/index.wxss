    linear-gradient(180deg, #fffaf5 0%, #fff4ea 48%, #ffffff 100%);
  overflow-x: hidden;
}

.hero-bg {
  height: 650rpx;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.94) 0%, rgba(255,244,232,0.92) 100%);
