.page-index {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff7f0 0%, #fff1e8 52%, #ffffff 100%);
  padding-bottom: calc(env(safe-area-inset-bottom) + 260rpx);
  position: relative;
  overflow: hidden;
}

.login-banner {
  position: relative;
  z-index: 2;
  margin: 20rpx 28rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #F28C38 0%, #D96A14 100%);
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(242, 140, 56, 0.3);
}

.login-banner-icon {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.login-banner-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.login-banner-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.login-banner-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 2rpx;
}

.login-banner-arrow {
  font-size: 24rpx;
  font-weight: bold;
  color: #FFFFFF;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 999rpx;
}

.hero-bg {
  position: absolute;
  inset: 0 0 auto 0;
  height: 560rpx;
  overflow: hidden;
  z-index: 0;
  background:
    radial-gradient(circle at 14% 22%, rgba(47, 184, 117, 0.2), transparent 190rpx),
    radial-gradient(circle at 86% 10%, rgba(255, 61, 110, 0.22), transparent 210rpx),
    linear-gradient(135deg, #fff8f0 0%, #ffe2d0 100%);
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(91,43,111,0.06) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(91,43,111,0.06) 1rpx, transparent 1rpx);
  background-size: 44rpx 44rpx;
  mask-image: linear-gradient(180deg, #000 0%, transparent 92%);
}

.hero-orbit {
  position: absolute;
  border-radius: 40%;
  transform: rotate(-12deg);
  animation: float 7s ease-in-out infinite;
}

.orbit-one {
  width: 260rpx;
  height: 260rpx;
  top: 80rpx;
  right: -80rpx;
  background: #ff6b1a;
  opacity: 0.18;
}

.orbit-two {
  width: 180rpx;
  height: 180rpx;
  top: 260rpx;
  left: -72rpx;
  background: #5b2b6f;
  opacity: 0.12;
  animation-delay: -3s;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(-12deg); }
  50% { transform: translateY(-18rpx) rotate(8deg); }
}

.header {
  position: relative;
  z-index: 1;
  padding: 50rpx 32rpx 28rpx;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  height: 44rpx;
  padding: 0 18rpx;
  background: rgba(255,255,255,0.78);
  border: 1rpx solid rgba(255,107,26,0.25);
  border-radius: 999rpx;
  color: #5b2b6f;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 28rpx rgba(91,43,111,0.08);
}

.eyebrow-icon {
  width: 28rpx;
  height: 28rpx;
}

.title-wrap {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
}

.title-icon {
  width: 76rpx;
  height: 76rpx;
  filter: drop-shadow(0 10rpx 20rpx rgba(255,107,26,0.22));
}

.brand-title-icon {
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(255, 90, 31, 0.22);
}

.title {
  font-size: 58rpx;
  font-weight: 900;
  color: #2a1735;
  line-height: 1;
}

.subtitle {
  display: block;
  width: 560rpx;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6d536c;
  line-height: 1.6;
}

.config-card {
  position: relative;
  z-index: 1;
  margin: 0 28rpx 28rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255,255,255,0.9);
  border: 2rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 18rpx 56rpx rgba(91,43,111,0.13);
  backdrop-filter: blur(18rpx);
  opacity: 0;
  animation: fadeInUp 0.55s ease forwards;
}

.panel-heading {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 26rpx;
}

.panel-title {
  display: block;
  font-size: 34rpx;
  font-weight: 850;
  color: #2a1735;
}

.panel-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #a78a96;
}

.panel-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #2a1735;
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
}

.config-row {
  margin-bottom: 26rpx;
}

.config-row:last-child {
  margin-bottom: 0;
}

.config-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #6d536c;
  font-weight: 800;
}

.label-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.count-options,
.config-options {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.count-pill {
  width: 126rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #fff8f0;
  border: 2rpx solid #ffd7c2;
  color: #5b2b6f;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 -4rpx 0 rgba(255,107,26,0.08);
  transition: transform 0.2s ease;
}

.count-pill.active {
  color: #fff;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  border-color: transparent;
  box-shadow: 0 14rpx 32rpx rgba(255,107,26,0.32);
  transform: translateY(-4rpx);
}

.pill-number {
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.pill-unit {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.type-scroll,
.category-scroll,
.spice-scroll {
  white-space: nowrap;
}

.type-pill {
  flex-shrink: 0;
  min-height: 64rpx;
  padding: 8rpx 20rpx 8rpx 10rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #ffd7c2;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #5b2b6f;
  font-size: 24rpx;
  font-weight: 750;
}

.type-pill.active {
  color: #fff;
  border-color: transparent;
  background: linear-gradient(135deg, #5b2b6f 0%, #ff3d6e 52%, #ff7a1a 100%);
  box-shadow: 0 12rpx 26rpx rgba(255,61,110,0.24);
}

.pill-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 16rpx;
}

.action-area {
  position: relative;
  z-index: 1;
  padding: 0 28rpx;
  margin-top: 26rpx;
  margin-bottom: 42rpx;
  opacity: 0;
  animation: fadeInUp 0.55s ease 0.25s forwards;
}

.shuffle-btn {
  width: 100%;
  min-height: 104rpx;
  height: auto;
  line-height: normal;
  padding: 24rpx 30rpx;
  box-sizing: border-box;
  border-radius: 32rpx;
  border: none;
  color: #fff;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 18rpx 44rpx rgba(255,107,26,0.34);
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  overflow: hidden;
  white-space: normal;
}

.shuffle-btn::after {
  border: none;
}

.shuffle-btn:active {
  transform: scale(0.98);
}

.shuffle-btn.disabled {
  opacity: 0.62;
  box-shadow: none;
}

.shuffle-icon {
  width: 46rpx;
  height: 46rpx;
  flex-shrink: 0;
}

.shuffle-btn text {
  display: block;
  line-height: 1.25;
  overflow: visible;
}

.history-card {
  position: relative;
  z-index: 1;
  margin: 30rpx 28rpx 0;
  padding: 28rpx;
  border-radius: 30rpx;
  background: #fff;
  border: 2rpx solid rgba(255,215,194,0.9);
  box-shadow: 0 18rpx 46rpx rgba(91,43,111,0.10);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 850;
  color: #2a1735;
}

.section-more {
  font-size: 24rpx;
  color: #ff3d6e;
  font-weight: 700;
}

.history-scroll {
  white-space: nowrap;
}

.history-item {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  min-width: 190rpx;
  height: 96rpx;
  padding: 0 22rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  color: #2a1735;
  background: linear-gradient(135deg, #fff7f0 0%, #ffffff 100%);
  border: 1rpx solid #ffd7c2;
}

.history-name {
  font-size: 28rpx;
  font-weight: 850;
}

.history-category {
  margin-top: 4rpx;
  color: #a78a96;
  font-size: 21rpx;
  font-weight: 700;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(34rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* V2 polish */
.config-card,
.history-card {
  border-radius: 38rpx;
  border-color: rgba(254,215,170,0.95);
  box-shadow: var(--shadow-clay);
}

.panel-badge {
  background: linear-gradient(135deg, #5b2b6f 0%, #9a3412 100%);
}

.shuffle-btn {
  box-shadow: 0 20rpx 48rpx rgba(255,90,31,0.34);
}

.history-card {
  background: linear-gradient(180deg, #ffffff 0%, #fffaf6 100%);
}

/* Reference replica polish */
.page-index {
