  transform: rotate(-10deg);
}

.hero-leaf {
  width: 48rpx;
  height: 48rpx;
  right: 178rpx;
  top: 190rpx;
  animation-delay: -2.5s;
}

.hero-tomato {
  width: 72rpx;
  height: 72rpx;
  left: 54rpx;
  top: 104rpx;
  opacity: 0.34;
  animation-delay: -4s;
}

