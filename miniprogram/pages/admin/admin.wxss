.page-admin {
  min-height: 100vh;
  background: #FFF9F3;
  padding: 24rpx 28rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
}

.admin-hero {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #5b2b6f 0%, #9a3412 58%, #ff6b1a 100%);
  box-shadow: 0 16rpx 38rpx rgba(91, 43, 111, 0.16);
}

.admin-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.admin-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
}

.admin-icon { width: 42rpx; height: 42rpx; }
.admin-copy { flex: 1; min-width: 0; }
.admin-title { display: block; font-size: 34rpx; font-weight: 800; line-height: 1.2; }
.admin-subtitle { display: block; margin-top: 5rpx; color: rgba(255, 255, 255, 0.76); font-size: 21rpx; }
.admin-status { flex-shrink: 0; padding: 7rpx 14rpx; border-radius: 999rpx; color: #eafff2; background: rgba(47, 184, 117, 0.28); font-size: 20rpx; font-weight: 700; }

.admin-metrics {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  overflow: hidden;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.12);
}

.metric-item { min-width: 0; padding: 18rpx 8rpx; display: flex; flex-direction: column; align-items: center; border-right: 1rpx solid rgba(255, 255, 255, 0.16); }
.metric-item:last-child { border-right: 0; }
.metric-value { font-size: 34rpx; font-weight: 850; line-height: 1; font-variant-numeric: tabular-nums; }
.metric-value.danger { color: #ffd7d7; }
.metric-label { margin-top: 8rpx; color: rgba(255, 255, 255, 0.72); font-size: 19rpx; white-space: nowrap; }

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  background: #FFFFFF;
  border: 2rpx solid #F0DCC8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #3D2B1F;
}

.search-btn {
  padding: 0 32rpx;
  height: 76rpx;
  line-height: 76rpx;
  background: #F28C38;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 16rpx;
  font-weight: 750;
}

.stats-row {
  margin-bottom: 20rpx;
}

.stats-text {
  font-size: 24rpx;
  color: #7A6258;
}

.loading-tip,
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #A89288;
  font-size: 28rpx;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.user-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 215, 194, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(91, 43, 111, 0.06);
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.user-name-wrap {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #3D2B1F;
}

.user-username {
  display: block;
  font-size: 22rpx;
  color: #A89288;
  margin-top: 4rpx;
}

.user-badges {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.badge {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.badge.admin {
  background: #FFF3E4;
  color: #F28C38;
}

.badge.disabled {
  background: #FFEBEE;
  color: #E74C3C;
}

.badge.self {
  background: #E8F5E9;
  color: #4CAF50;
}

.user-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #A89288;
}

.user-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.action-btn {
  min-height: 58rpx;
  box-sizing: border-box;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: bold;
  text-align: center;
}

.btn-default {
  background: #FFF1E4;
  color: #F28C38;
}

.btn-success {
  background: #E8F5E9;
  color: #4CAF50;
}

.btn-warn {
  background: #FFF3E0;
  color: #FF9800;
}

.btn-danger {
  background: #FFEBEE;
  color: #E74C3C;
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-top: 40rpx;
}

.page-btn {
  padding: 16rpx 36rpx;
  background: #FFFFFF;
  border: 2rpx solid #F0DCC8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #F28C38;
  font-weight: bold;
}

.page-btn.disabled {
  color: #C4B0A4;
  background: #F8F2F0;
}

.page-info {
  font-size: 26rpx;
  color: #7A6258;
}
