.bubble-wrap {
  display: flex;
  align-items: flex-start;
  margin-bottom: 22rpx;
  padding: 0 28rpx;
}

.bubble-wrap.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 18rpx rgba(91,43,111,0.12);
}

.bubble {
  max-width: 76%;
  padding: 22rpx 26rpx;
  border-radius: 26rpx;
  font-size: 28rpx;
  line-height: 1.62;
  word-break: break-word;
}

.ai-bubble {
  background: #ffffff;
  color: #2a1735;
  border-top-left-radius: 10rpx;
  border: 1rpx solid rgba(255,215,194,0.92);
  box-shadow: 0 10rpx 26rpx rgba(91,43,111,0.08);
}

.user-bubble {
  color: #ffffff;
  border-top-right-radius: 10rpx;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 12rpx 26rpx rgba(255,107,26,0.22);
}

.bubble-text {
  white-space: pre-wrap;
}
