.bubble-wrap {
  display: flex;
  align-items: flex-start;
  margin-bottom: 22rpx;
  padding: 0 28rpx;
}

.bubble-wrap.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 18rpx rgba(91,43,111,0.12);
}

.bubble {
  max-width: 76%;
  padding: 22rpx 26rpx;
  border-radius: 26rpx;
  font-size: 28rpx;
  line-height: 1.62;
  word-break: break-word;
}

.ai-bubble {
  background: #ffffff;
  color: #2a1735;
  border-top-left-radius: 10rpx;
  border: 1rpx solid rgba(255,215,194,0.92);
  box-shadow: 0 10rpx 26rpx rgba(91,43,111,0.08);
}

.user-bubble {
  color: #ffffff;
  border-top-right-radius: 10rpx;
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 12rpx 26rpx rgba(255,107,26,0.22);
}

.bubble-text {
  white-space: pre-wrap;
}

/* Reference replica polish */
.bubble-wrap {
  margin-bottom: 26rpx;
  padding: 0 30rpx;
}

.avatar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #fff7ef;
  border: 2rpx solid rgba(255,255,255,0.82);
}

.bubble {
  max-width: 74%;
  padding: 26rpx 30rpx;
  border-radius: 28rpx;
  font-size: 31rpx;
  line-height: 1.62;
}

.ai-bubble {
  border-top-left-radius: 12rpx;
  border-color: rgba(255, 215, 194, 0.96);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(255,255,255,0.92) 100%);
  box-shadow: 0 16rpx 34rpx rgba(91, 43, 111, 0.10);
}

.user-bubble {
  position: relative;
  border-top-right-radius: 12rpx;
  background:
    radial-gradient(circle at 88% 16%, rgba(255,255,255,0.24), transparent 54rpx),
    linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 16rpx 34rpx rgba(255, 90, 31, 0.26);
}

.user-bubble::after {
  content: '';
  position: absolute;
  right: -10rpx;
  bottom: -10rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: inset 0 0 0 7rpx rgba(255, 122, 26, 0.92);
}
