.bubble-wrap {
  display: flex;
  align-items: flex-start;
  margin-bottom: 22rpx;
  padding: 0 24rpx;
}

.bubble-wrap.user { flex-direction: row-reverse; }

.avatar {
  width: 64rpx;
  height: 64rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  border: 2rpx solid #ffffff;
  border-radius: 50%;
  background: #fff7ef;
  box-shadow: 0 7rpx 18rpx rgba(91, 43, 111, 0.1);
}

.bubble {
  max-width: 76%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.62;
  word-break: break-word;
}

.ai-bubble {
  min-height: 64rpx;
  border: 1rpx solid #ffd1b6;
  border-top-left-radius: 8rpx;
  color: #2a1735;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(91, 43, 111, 0.07);
}

.user-bubble {
  border-top-right-radius: 8rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ff466f 0%, #ff711f 100%);
  box-shadow: 0 10rpx 24rpx rgba(255, 90, 31, 0.2);
}

.bubble-text { display: block; white-space: normal; }
