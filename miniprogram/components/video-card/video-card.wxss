.video-card {
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  overflow: hidden;
  border: 2rpx solid rgba(255,215,194,0.9);
  box-shadow: 0 14rpx 34rpx rgba(91,43,111,0.10);
}

.video-card:active {
  transform: scale(0.985);
}

.video-card.featured {
  border: none;
  box-shadow: 0 20rpx 52rpx rgba(91,43,111,0.16);
}

.cover-wrap {
  position: relative;
  width: 100%;
  padding-top: 62%;
  background: #2a1735;
  overflow: hidden;
}

.featured .cover-wrap {
  padding-top: 56.25%;
}

.cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-tint {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(42,23,53,0.04), rgba(42,23,53,0.42));
}

.play-btn {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  background: rgba(255,255,255,0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 28rpx rgba(42,23,53,0.24);
}

.featured .play-btn {
  width: 96rpx;
  height: 96rpx;
}

.play-triangle {
  width: 0;
  height: 0;
  margin-left: 6rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #ff3d6e;
}

.duration-badge,
.category-badge {
  position: absolute;
  bottom: 14rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 850;
  background: rgba(42,23,53,0.74);
}

.duration-badge {
  right: 14rpx;
}

.category-badge {
  left: 14rpx;
  background: rgba(255,107,26,0.92);
}

.card-info {
  padding: 20rpx 20rpx 22rpx;
}

.featured .card-info {
  padding: 26rpx 28rpx 30rpx;
}

.card-title {
  color: #2a1735;
  font-size: 27rpx;
  line-height: 1.38;
  font-weight: 850;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.featured .card-title {
  font-size: 34rpx;
  font-weight: 900;
}

.card-desc {
  display: block;
  margin-top: 10rpx;
  color: #6d536c;
  font-size: 24rpx;
  line-height: 1.55;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
}

.chef-avatar {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #fff1e8;
}

.chef-name {
  color: #6d536c;
  font-size: 22rpx;
  font-weight: 750;
}

.views {
  margin-left: auto;
  color: #a78a96;
  font-size: 20rpx;
  font-weight: 700;
}
