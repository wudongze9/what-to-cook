.step-item {
  display: flex;
  padding: 0 0 32rpx 0;
  position: relative;
}

.timeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.step-number {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  flex-shrink: 0;
}

.step-completed .step-number {
  background: var(--color-success, #4CAF50);
}

.step-current .step-number {
  background: var(--color-primary, #F28C38);
  box-shadow: 0 0 0 8rpx rgba(242, 140, 56, 0.15);
}

.step-upcoming .step-number {
  background: var(--color-border, #F0DCC8);
  color: var(--color-text-tertiary, #A89288);
}

.step-number.pulse {
  animation: pulse-glow 1.5s ease-in-out infinite;
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 0 8rpx rgba(242, 140, 56, 0.15); }
  50% { box-shadow: 0 0 0 16rpx rgba(242, 140, 56, 0.25); }
}

.check-icon {
  font-size: 32rpx;
  font-weight: 700;
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  min-height: 40rpx;
  margin-top: 8rpx;
}

.step-completed .timeline-line {
  background: var(--color-success, #4CAF50);
  opacity: 0.4;
}

.step-current .timeline-line {
  background: linear-gradient(to bottom, var(--color-primary, #F28C38), var(--color-border, #F0DCC8));
}

.step-upcoming .timeline-line {
  background: var(--color-border, #F0DCC8);
}

.step-content {
  flex: 1;
  background: var(--color-surface, #FFFFFF);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid var(--color-border, #F0DCC8);
}

.step-current .step-content {
  border-color: var(--color-primary, #F28C38);
  border-width: 2rpx;
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text, #3D2B1F);
}

.step-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.time-badge {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #A89288);
  background: var(--color-bg-secondary, #FFF1E4);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.status-badge.completed {
  color: var(--color-success, #4CAF50);
  background: rgba(76, 175, 80, 0.1);
}

.status-badge.current {
  color: var(--color-primary, #F28C38);
  background: var(--color-primary-lightest, #FFF3E4);
}

.step-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary, #7A6258);
  line-height: 1.6;
}
