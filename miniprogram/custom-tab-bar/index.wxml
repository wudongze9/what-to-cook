<view class="tab-shell">
  <view class="tab-bar">
    <view
      wx:for="{{list}}"
      wx:key="index"
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-index="{{index}}"
      data-path="{{item.pagePath}}"
      bindtap="switchTab"
    >
      <view class="tab-icon-wrap">
        <image class="tab-icon" src="{{item.icon}}" mode="aspectFit" />
      </view>
      <text class="tab-text">{{item.text}}</text>
    </view>
  </view>
</view>
