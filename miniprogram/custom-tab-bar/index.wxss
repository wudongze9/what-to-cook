.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 0 22rpx calc(env(safe-area-inset-bottom) + 12rpx);
  pointer-events: none;
}

.tab-bar {
  height: 104rpx;
  display: flex;
  align-items: center;
  border-radius: 34rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(255,215,194,0.92);
  box-shadow: 0 16rpx 46rpx rgba(42,23,53,0.15);
  backdrop-filter: blur(18rpx);
  pointer-events: auto;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #a78a96;
}

.tab-icon-wrap {
  width: 46rpx;
  height: 46rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.tab-icon {
  width: 38rpx;
  height: 38rpx;
  opacity: 0.56;
  transition: all 0.2s ease;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 750;
}

.tab-item.active .tab-icon-wrap {
  background: linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 8rpx 18rpx rgba(255,107,26,0.25);
  transform: translateY(-6rpx);
}

.tab-item.active .tab-icon {
  opacity: 1;
  filter: drop-shadow(0 2rpx 2rpx rgba(255,255,255,0.35));
}

.tab-item.active .tab-text {
  color: #ff6b1a;
}

/* Reference replica polish */
.tab-shell {
  padding: 0 24rpx calc(env(safe-area-inset-bottom) + 14rpx);
}

.tab-bar {
  height: 118rpx;
  border-radius: 36rpx;
  background: rgba(255,255,255,0.95);
  border: 2rpx solid rgba(255, 215, 194, 0.92);
  box-shadow:
    0 18rpx 50rpx rgba(91, 43, 111, 0.14),
    inset 0 -4rpx 0 rgba(255, 107, 26, 0.03);
}

.tab-item {
  height: 106rpx;
  gap: 6rpx;
}

.tab-icon-wrap {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
}

.tab-icon {
  width: 42rpx;
  height: 42rpx;
  opacity: 0.62;
}

.tab-text {
  font-size: 23rpx;
  line-height: 1.1;
}

.tab-item.active .tab-icon-wrap {
  background:
    radial-gradient(circle at 24% 18%, rgba(255,255,255,0.32), transparent 28rpx),
    linear-gradient(135deg, #ff3d6e 0%, #ff7a1a 100%);
  box-shadow: 0 12rpx 24rpx rgba(255, 90, 31, 0.28);
  transform: translateY(-8rpx);
}

.tab-item.active .tab-text {
  color: #ff5a1f;
  font-weight: 900;
}
